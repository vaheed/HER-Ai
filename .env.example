# HER AI environment template
# Copy this file to `.env` before running docker compose.
# This template is docker-first: hostnames use compose service names.
# For running app outside docker, switch hosts to 127.0.0.1 as noted below.

# -----------------------------
# App identity and runtime
# -----------------------------
APP_NAME=her-ai
ENVIRONMENT=prod
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
REQUEST_TIMEOUT_SECONDS=20

# -----------------------------
# Service ports (host -> container)
# -----------------------------
POSTGRES_PORT=5432
REDIS_PORT=6379
OLLAMA_PORT=11434
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
JAEGER_UI_PORT=16686

# -----------------------------
# PostgreSQL container init
# -----------------------------
POSTGRES_DB=her
POSTGRES_USER=her
POSTGRES_PASSWORD=change-me

# -----------------------------
# Core infrastructure URLs (inside docker network)
# -----------------------------
DATABASE_URL=postgresql+asyncpg://her:change-me@postgres:5432/her
REDIS_URL=redis://redis:6379/0
WORKING_MEMORY_TTL_MINUTES=30

# -----------------------------
# LLM provider routing
# -----------------------------
# Order matters. Providers are tried left-to-right.
# Supported values: openai, anthropic, custom, ollama
PROVIDER_PRIORITY=openai,anthropic,custom,ollama

# -----------------------------
# OpenAI provider
# -----------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------
# Anthropic provider
# -----------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# -----------------------------
# Custom LLM provider
# -----------------------------
# Endpoint should accept OpenAI-style chat payloads.
CUSTOM_LLM_ENDPOINT=
CUSTOM_LLM_MODEL=custom-model
CUSTOM_LLM_API_KEY=

# -----------------------------
# Ollama provider
# -----------------------------
# IMPORTANT: for docker compose keep this as service hostname.
# If app runs on host machine, change to http://127.0.0.1:11434
OLLAMA_BASE_URL=http://ollama:11434
# Used by `ollama` CLI in the ollama-init service.
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------
# Embedding providers
# -----------------------------
# Supported values: ollama, custom, none
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=1536
CUSTOM_EMBEDDING_ENDPOINT=
CUSTOM_EMBEDDING_MODEL=custom-embedding-model
CUSTOM_EMBEDDING_API_KEY=

# -----------------------------
# Conversation pipeline tuning
# -----------------------------
CONVERSATION_TOKEN_BUDGET=1800
SEMANTIC_TOP_K=5
RECENT_EPISODE_LIMIT=8
ACTIVE_GOAL_LIMIT=5

# -----------------------------
# Telegram bot
# -----------------------------
TELEGRAM_BOT_TOKEN=
