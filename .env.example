# HER AI environment template
# Copy this file to `.env` and fill values for your environment.
# Never commit real secrets. Use a secret manager in production.

# -----------------------------
# App identity and runtime
# -----------------------------
APP_NAME=her-ai
ENVIRONMENT=dev
LOG_LEVEL=INFO
API_HOST=127.0.0.1
API_PORT=8000
REQUEST_TIMEOUT_SECONDS=20

# -----------------------------
# Core infrastructure
# -----------------------------
# Local default DSNs are for docker-compose development.
DATABASE_URL=postgresql+asyncpg://her:her@127.0.0.1:5432/her
REDIS_URL=redis://127.0.0.1:6379/0
WORKING_MEMORY_TTL_MINUTES=30

# -----------------------------
# LLM provider routing
# -----------------------------
# Order matters. Providers are tried left-to-right.
# Supported values: openai, anthropic, custom, ollama
PROVIDER_PRIORITY=openai,anthropic,custom,ollama

# -----------------------------
# OpenAI provider
# -----------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# -----------------------------
# Anthropic provider
# -----------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# -----------------------------
# Custom LLM provider
# -----------------------------
# Endpoint should accept OpenAI-style chat payloads.
CUSTOM_LLM_ENDPOINT=
CUSTOM_LLM_MODEL=custom-model
CUSTOM_LLM_API_KEY=

# -----------------------------
# Ollama provider
# -----------------------------
# For local docker-compose use: http://ollama:11434
# For host machine use:        http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# -----------------------------
# Embedding providers
# -----------------------------
# Supported values: ollama, custom, none
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=1536
CUSTOM_EMBEDDING_ENDPOINT=
CUSTOM_EMBEDDING_MODEL=custom-embedding-model
CUSTOM_EMBEDDING_API_KEY=

# -----------------------------
# Conversation pipeline tuning
# -----------------------------
CONVERSATION_TOKEN_BUDGET=1800
SEMANTIC_TOP_K=5
RECENT_EPISODE_LIMIT=8
ACTIVE_GOAL_LIMIT=5

# -----------------------------
# Telegram bot
# -----------------------------
# Create token via BotFather, then set here.
TELEGRAM_BOT_TOKEN=
